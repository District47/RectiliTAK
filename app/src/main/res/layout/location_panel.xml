<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/chat_bg"
    android:padding="12dp">

    <!-- Back button -->
    <Button
        android:id="@+id/locBackButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Back"
        android:textSize="12sp"
        android:textColor="@color/chat_accent"
        android:backgroundTint="@color/chat_input_bg"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Location Sharing"
        android:textColor="@color/chat_text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="16dp" />

    <!-- Auto-share toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/chat_input_bg"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Auto-Share Location"
            android:textColor="@color/chat_text"
            android:textSize="14sp" />

        <Switch
            android:id="@+id/locAutoShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Share frequency -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/chat_input_bg"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share Frequency"
            android:textColor="@color/chat_text"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/locFrequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/chat_bg"
            android:popupBackground="@color/chat_input_bg" />

    </LinearLayout>

    <!-- Share to -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/chat_input_bg"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share With"
            android:textColor="@color/chat_text"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/locShareWith"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/chat_bg"
            android:popupBackground="@color/chat_input_bg" />

    </LinearLayout>

    <!-- CoT icon type -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/chat_input_bg"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Map Icon"
            android:textColor="@color/chat_text"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/locCotIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/chat_bg"
            android:popupBackground="@color/chat_input_bg" />

    </LinearLayout>

    <!-- Manual share button -->
    <Button
        android:id="@+id/locShareNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share Location Now"
        android:textColor="#000000"
        android:backgroundTint="@color/chat_accent"
        android:layout_marginTop="16dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/locStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/chat_hint"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingTop="12dp" />

</LinearLayout>
