<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory android:title="Chat Appearance">

        <ListPreference
            android:key="chat.font_size"
            android:title="Font Size"
            android:summary="Message text size"
            android:entries="@array/font_size_labels"
            android:entryValues="@array/font_size_values"
            android:defaultValue="14" />

        <CheckBoxPreference
            android:key="chat.show_timestamps"
            android:title="Show Timestamps"
            android:summary="Display time on each message"
            android:defaultValue="false" />

        <CheckBoxPreference
            android:key="chat.compact_mode"
            android:title="Compact Mode"
            android:summary="Reduce spacing between messages"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Reticulum Network">

        <CheckBoxPreference
            android:key="rns.bridge_enabled"
            android:title="Enable RNS Bridge"
            android:summary="Start/stop the Reticulum bridge service"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="rns.transport_enabled"
            android:title="Enable Transport"
            android:summary="Act as a relay node for multi-hop routing"
            android:defaultValue="false" />

        <CheckBoxPreference
            android:key="rns.auto_enabled"
            android:title="WiFi/LAN Auto-Discovery"
            android:summary="Enable local network discovery. Disable if another Reticulum app (e.g. Sideband) is running."
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory android:title="TCP Bootstrap Peer">

        <CheckBoxPreference
            android:key="rns.tcp_enabled"
            android:title="Enable TCP Bootstrap"
            android:summary="Connect to a remote Reticulum node via TCP"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="rns.tcp_host"
            android:title="Host"
            android:summary="Hostname or IP of the TCP bootstrap peer"
            android:defaultValue="rns.beleth.net" />

        <EditTextPreference
            android:key="rns.tcp_port"
            android:title="Port"
            android:summary="TCP port of the bootstrap peer"
            android:defaultValue="4242" />

    </PreferenceCategory>

</PreferenceScreen>
